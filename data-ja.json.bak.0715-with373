{
  "基隆": {
    "routes": [
      {
        "name": "和平島・正濱漁港・廟口一日遊（ヘイワトウ・セイヒンギョコウ・ミャオコウイチニチユ）",
        "stops": [
          "正濱漁港彩虹屋",
          "阿根納造船廠遺址",
          "和平島公園",
          "中正公園",
          "基隆廟口夜市"
        ],
        "description": "基隆の海港を巡るクラシックなルートで、台版ヴェネツィアの彩色漁港からスタートし、廃墟の風景を楽しんだ後、和平島公園で海食地形を観賞し、夕方には中正公園で港の全景を眺め、夜には廟口夜市で美味しい料理を堪能できます。",
        "tags": [
          "一般路線"
        ]
      },
      {
        "name": "八斗子潮境・海科館一日遊（ハットウシチョウキョウ・カイカカンイチニチユ）",
        "stops": [
          "望海巷跨海景觀橋",
          "國立海洋科技博物館",
          "深澳鐵道自行車",
          "八斗子觀光漁港",
          "潮境公園",
          "忘憂谷（望幽谷）"
        ],
        "description": "親子で楽しめる自然を満喫するルートです。まずは望海巷の海景観橋を渡り、美しい海の景色を楽しみ、その後海科館や深澳鉄道の自転車に乗ります。午後は潮境公園で飛天掃把やオウムガイの滑り台を楽しみ、最後に忘憂谷の歩道を散策して緑豊かな山谷と絶景の海を堪能しましょう。",
        "tags": [
          "一般路線"
        ]
      },
      {
        "name": "外木山・佛手洞・情人湖一日遊（ガイモクサン・ブッショウドウ・ジョウニンコイチニチユ）",
        "stops": [
          "大武崙砲台",
          "情人湖",
          "外木山濱海風景區",
          "海興游泳池",
          "仙洞巖",
          "佛手洞",
          "白米甕砲台"
        ],
        "description": "基隆の西岸に隠れた秘境を巡るルートです。大武崙砲台から歴史的遺跡を見学し、情人湖を散策。その後、外木山の海興プールで無料で水遊びやシュノーケリングを楽しみ、最後に台湾最大の海食洞、迷宮仙洞岩と佛手洞を探検します。",
        "tags": [
          "一般路線"
        ]
      },
      {
        "name": "基隆嶼登島一日遊（キロンシュトウトウシイチニチユ）",
        "stops": [
          "基隆港",
          "基隆嶼",
          "基隆嶼燈塔",
          "和平島公園"
        ],
        "description": "夏季限定の特別なルートです。碧砂漁港から船で基隆嶼に上陸し、島内を巡って火山島の地質景観を楽しみます。灯台に登って大海を一望し、帰りには和平島公園にも立ち寄れます。",
        "tags": [
          "一般路線"
        ]
      },
      {
        "name": "基隆市區文化一日遊（キロンシクブンカイチニチユ）",
        "stops": [
          "基隆車站",
          "太平青鳥書局",
          "海洋廣場",
          "二沙灣砲台（海門天險）",
          "球子山燈塔",
          "基隆廟口夜市"
        ],
        "description": "市内の文化を散策するルートです。基隆駅から出発し、太平青鳥書局で本を読みながらコーヒーを楽しみ、海洋広場でクルーズ船の入港を観察します。二沙湾砲台の歴史的遺跡を訪れ、球子山灯台からの絶景を堪能し、夜は廟口夜市で食べ歩きを楽しみましょう。",
        "tags": [
          "一般路線"
        ]
      },
      {
        "name": "基隆雨天散策・海科館到廟口（キロンウテンサンソク・カイカカンカラミャオコウ）",
        "description": "雨の日でも基隆を楽しめるプランです。海科館で海洋の知識を学び、陽明海洋文化芸術館で航運の歴史を見学。その後、太平青鳥書局でゆっくり本を読み、夕方には廟口夜市で温かいスープを楽しみましょう。",
        "stops": [
          "國立海洋科技博物館",
